<Window x:Class="Konyvtarapp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Konyvtarapp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Hozzáadás / Törlés sor -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
            <TextBox Width="120" Name="titleBox" Margin="5" PlaceholderText="Cím"/>
            <TextBox Width="120" Name="authorBox" Margin="5" PlaceholderText="Szerző"/>
            <TextBox Width="80" Name="yearBox" Margin="5" PlaceholderText="Év"/>
            <TextBox Width="80" Name="priceBox" Margin="5" PlaceholderText="Ár"/>

            <Button Content="Hozzáadás" Click="AddBook" Margin="5"/>
            <Button Content="Törlés" Click="DeleteBook" Margin="5"/>
        </StackPanel>

        <!-- Keresés / Frissítés sor -->
        <StackPanel Orientation="Horizontal" Grid.Row="1">
            <TextBox Width="200" Name="searchBox" Margin="5" PlaceholderText="Keresés..."/>
            <Button Content="Keresés" Click="SearchBook" Margin="5"/>
            <Button Content="Frissítés" Click="LoadBooks" Margin="5"/>
        </StackPanel>

        <!-- DataGrid a könyvek listázásához -->
        <DataGrid Name="bookGrid" Grid.Row="2" Margin="5"/>

    </Grid>
</Window>